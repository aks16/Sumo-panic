import model.Keponom;
import org.junit.Before;
import org.junit.BeforeClass;
import org.junit.Test;
import static org.junit.Assert.*;

public class KeponomTest {
    // On déclare l'objet en static pour qu'il soit partagé (BeforeClass) 
    private static Keponom keponom;

    // 1. S'exécute UNE SEULE FOIS au tout début
    @BeforeClass
    public static void setUpBeforeClass() {
        keponom = new Keponom(); // Création de l'instance
    }

    // 2. S'exécute AVANT CHAQUE méthode @Test
    @Before
    public void setUp() {
        // Remet le Képonom à son état initial (hp = 17) 
        // Cela garantit que le Test A n'influence pas le Test B.
        keponom.init(); 
    }

    // 3. Les méthodes de test (cas concrets) [cite: 106, 228]
    @Test
    public void testDamageNormal() {
        keponom.damage(5);
        // assertEquals(attendu, actuel)
        assertEquals(12, keponom.getHP()); 
    }

        @Test
    public void testMortAutomatique() {
        keponom.damage(17); // On inflige le max de dégâts
        assertEquals(0, keponom.getHP()); // Vérifie la valeur exacte [cite: 166]
        assertTrue(keponom.isDead());      // Vérifie l'état logique [cite: 238]
    }
}


